class Solution {
    public boolean canAliceWin(int[] nums) {
        int n = nums.length;
        int singlesum = 0, doublesum = 0;
        for(int i = 0; i < n; i++){
            if(nums[i] < 10){
                singlesum += nums[i];
            }
            if(nums[i] > 9){
                doublesum += nums[i];
            }
        }
        if(singlesum > doublesum){
            return true;
        }
        else if(doublesum > singlesum){
            return true;
        }
        else{
            return false;
        }
        
    }
}
